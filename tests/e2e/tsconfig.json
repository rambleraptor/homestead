{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "lib": ["es2022", "dom"],
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true
  },
  "include": ["config/**/*", "fixtures/**/*", "utils/**/*", "pages/**/*", "tests/**/*", "playwright.config.ts"]
}
