# PocketBase Configuration
# Use the Next.js proxy by default to avoid CORS issues and Cloudflare Access blocking
# In production, leave this commented out to use the default /api/pb proxy
# In development, you can override this if needed, but the proxy will still work
# NEXT_PUBLIC_POCKETBASE_URL=/api/pb

# App Configuration
NEXT_PUBLIC_APP_NAME=HomeOS

# Web Push Notifications
# Generate your own VAPID keys using: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BEL8xH1kLqr8C9F0b3X7Y_Z5K6J4W8Q2M1N3P5R7T9V0A2C4E6G8I0K2M4O6Q8S0U2W4Y6A8C0E2G4I6K8M0O2

# Server-side VAPID keys (for API routes and PocketBase)
# IMPORTANT: Keep VAPID_PRIVATE_KEY secret! Never commit real values to git
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=mailto:admin@example.com

# Gemini AI API Key for grocery categorization (server-side only)
# Get your API key from: https://makersuite.google.com/app/apikey
# Note: This is NOT prefixed with NEXT_PUBLIC_ to keep it server-side only for security
GEMINI_API_KEY=your_gemini_api_key_here

# PocketBase Admin Credentials (for server-side notification sending)
# These credentials are used by the notification sender to authenticate with PocketBase
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=your_admin_password_here
